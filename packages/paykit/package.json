{
  "name": "paykitjs",
  "version": "0.1.0",
  "description": "TypeScript-first payments orchestration framework for modern SaaS",
  "keywords": [
    "creem",
    "orchestration",
    "paddle",
    "payments",
    "paypal",
    "polar",
    "stripe",
    "subscriptions",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/getpaykit/paykit.git"
  },
  "bin": {
    "paykitjs": "./dist/cli/index.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./handlers/next": "./src/handlers/next.ts",
    "./client": "./src/client/index.ts"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./handlers/next": {
        "types": "./dist/handlers/next.d.ts",
        "default": "./dist/handlers/next.js"
      },
      "./client": {
        "types": "./dist/client/index.d.ts",
        "default": "./dist/client/index.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "scripts": {
    "build": "tsdown --config tsdown.config.ts",
    "db:generate": "drizzle-kit generate --config src/database/drizzle.config.ts"
  },
  "dependencies": {
    "@better-fetch/fetch": "^1.1.21",
    "@clack/prompts": "^1.1.0",
    "better-call": "^2.0.2",
    "commander": "^12.1.0",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "jiti": "^2.6.1",
    "pg": "^8.20.0",
    "picocolors": "^1.1.1",
    "stripe": "^19.1.0",
    "typescript": "^5.9.2",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.3.15",
    "@types/pg": "^8.18.0",
    "drizzle-kit": "^0.31.5",
    "pg-mem": "^3.0.14",
    "tsdown": "^0.21.1",
    "vitest": "^4.0.18"
  }
}
